# ============================================================
# Riyadh Dictionary Image Pipeline - Backend
# Copy this to .env and fill in your real values
# ============================================================

# --- MongoDB Atlas ---
# Get from: https://cloud.mongodb.com → cluster → Connect → Drivers
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=riyadh_dictionary

# --- Supabase Storage ---
# Get from: Supabase project → Settings → API (Project URL, not /rest/v1/)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_BUCKET=dictionary-images

# --- OpenAI (for regenerate endpoint) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_PROMPT_REPAIR_MODEL=gpt-4o-mini

# --- Google Sheets (migration) ---
GOOGLE_SA_KEYFILE=./google_service_account.json
SHEETS_SPREADSHEET_ID=
SHEETS_WORKSHEET_NAME=

# --- API Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must match VITE_API_KEY in frontend/.env
API_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# --- App settings ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
