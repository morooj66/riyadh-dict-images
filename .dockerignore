# Secrets — never baked into Docker image
**/.env
**/.env.*
!**/.env.example

# Python artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.venv/
**/venv/

# Node artifacts
**/node_modules/
# Note: frontend/dist/ must NOT be ignored — it's the pre-built React app
# that the Dockerfile copies into the container via: COPY frontend/dist/ /app/frontend/dist/

# Local MongoDB data
backend/.local/
backend/data/mongo_backup/

# Git
.git/
.gitignore

# macOS
**/.DS_Store

# Editor
.cursor/
**/.idea/
**/.vscode/

# Test / notebooks
backend/tests/
notebooks/
m/

# Google credentials
**/google_service_account.json
